# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_training

# JWT
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# AI Provider profile (PAID=openai, FREE=gemini)
AI_PROFILE=PAID

# OpenAI (PAID profile)
OPENAI_API_KEY=sk-...
OPENAI_MODEL_TEXT=gpt-4o
OPENAI_MODEL_CAPTION=gpt-4o-mini
OPENAI_MODEL_TRANSCRIBE=whisper-1
OPENAI_MODEL_EMBEDDING=text-embedding-3-large
AI_EMBEDDING_DIM=3072
OPENAI_COST_TEXT_INPUT_PER_1M=0
OPENAI_COST_TEXT_OUTPUT_PER_1M=0
OPENAI_COST_EMBED_INPUT_PER_1M=0
OPENAI_COST_TRANSCRIBE_PER_MINUTE=0

# Gemini (FREE profile)
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL_TEXT=gemini-2.5-flash
GEMINI_MODEL_CAPTION=gemini-2.5-flash
GEMINI_MODEL_TRANSCRIBE=gemini-2.5-flash
GEMINI_MODEL_EMBEDDING=gemini-embedding-001
GEMINI_MIN_REQUEST_INTERVAL_SECONDS=12
GEMINI_MAX_RETRIES=3
GEMINI_RETRY_BASE_SECONDS=2
GEMINI_COST_TEXT_INPUT_PER_1M=0
GEMINI_COST_TEXT_OUTPUT_PER_1M=0
GEMINI_COST_EMBED_INPUT_PER_1M=0
GEMINI_COST_TRANSCRIBE_PER_MINUTE=0

# S3-compatible storage (MinIO local / Cloudflare R2 in prod)
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=ai-training-assets
S3_PUBLIC_URL=http://localhost:9000/ai-training-assets

# CORS (en producción agregar también el dominio de Netlify, separado por comas)
CORS_ORIGINS=http://localhost:5173

# Frontend (Vite / Netlify)
VITE_API_BASE_URL=http://localhost:8000
